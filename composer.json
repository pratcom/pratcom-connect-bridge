{
    "name": "pratcom/pratcom-connect-bridge",
    "description": "Plugin WP universel pour connecter un site WordPress a l API Pratcom Connect",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "yahnis-elsts/plugin-update-checker": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "Pratcom\\Connect\\Bridge\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
