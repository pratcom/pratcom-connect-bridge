  "presets": [
    {
      "id": "ga4",
      "name": "Google Analytics 4",
      "provider": "Google",
      "category": "statistics",
      "blockedByDefault": true,
      "description": {
        "fr": "Mesure d'audience du site (pages visitées, provenance, durée des visites).",
        "en": "Site audience measurement (pages visited, traffic source, visit duration)."
      },
      "detect": { "plugins": ["google-site-kit/google-site-kit.php"] },
      "blocking": { "scriptPatterns": ["googletagmanager.com/gtag/js", "google-analytics.com"] },
      "cookies": [
        { "name": "_ga", "expiry": { "fr": "2 ans", "en": "2 years" }, "thirdParty": false, "description": { "fr": "Distingue les visiteurs de façon anonyme.", "en": "Distinguishes visitors anonymously." } },
        { "name": "_ga_*", "expiry": { "fr": "2 ans", "en": "2 years" }, "thirdParty": false, "description": { "fr": "Conserve l'état de la session de mesure.", "en": "Persists measurement session state." } },
        { "name": "_gid", "expiry": { "fr": "24 heures", "en": "24 hours" }, "thirdParty": false, "description": { "fr": "Distingue les visiteurs (courte durée).", "en": "Distinguishes visitors (short-lived)." } }
      ]
    },
    {
      "id": "gtm",
      "name": "Google Tag Manager",
      "provider": "Google",
      "category": "marketing",
      "blockedByDefault": true,
